# MedAI Dermatology - Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── MongoDB (optional, leave empty to use JSON fallback) ─────
USE_MONGODB=false
MONGODB_URL=

# ── Preprocessing Mode ───────────────────────────────────────
# auto | yolo | opencv | none
PREPROCESSING_MODE= none

# ── Port Settings ────────────────────────────────────────────
FRONTEND_PORT=80       # Port to expose frontend on host

# ── GPU (uncomment and set if using GPU server) ──────────────
# CUDA_VISIBLE_DEVICES=0
