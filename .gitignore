# ============================================
# DATA DIRECTORIES - Keep samples only
# ============================================

# Ignore all data first
data/

# Then allow specific structure and samples
!data/
!data/README.md

# RAW DATA - Allow structure and sample images
!data/raw/
!data/raw/dermnet/
!data/raw/dermnet/test/
!data/raw/dermnet/test/*/
!data/raw/dermnet/test/*/*.jpg
!data/raw/dermnet/test/*/*.jpeg
!data/raw/dermnet/test/*/*.png

!data/raw/isic_2019/
!data/raw/isic_2019/ISIC_2019_Training_Input/
!data/raw/isic_2019/ISIC_2019_Training_Input/*.jpg
!data/raw/isic_2019/*.csv

!data/raw/pad_ufes_20/
!data/raw/pad_ufes_20/images/
!data/raw/pad_ufes_20/images/*/
!data/raw/pad_ufes_20/images/*/*.png
!data/raw/pad_ufes_20/*.csv

# PROCESSED DATA - Allow structure and sample images
!data/processed/
!data/processed/train/
!data/processed/train/*/
!data/processed/train/*/*.jpg

!data/processed/val/
!data/processed/val/*/
!data/processed/val/*/*.jpg

