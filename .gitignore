# ==========================================
# DATA FOLDER CONFIGURATION
# ==========================================
# 1. Bỏ qua tất cả các file bên trong thư mục data
data/**/*

# 2. Bỏ chặn (cho phép) Git đọc các thư mục con
!data/**/

# 3. Cho phép theo dõi các file metadata và file giữ chỗ
!data/**/*.csv
!data/**/*.md
!data/**/.gitkeep

# 4. Đảm bảo chặn tuyệt đối các định dạng ảnh trong data
data/**/*.jpg
data/**/*.jpeg
data/**/*.png
# ==========================================

# LARGE FILES & ARCHIVES
*.zip
*.rar
*.tar.gz

# BACKEND TEMPORARY FILES
backend/uploads/
backend/history.json

# AI Models (Only upload V3.0)
backend/ml_models/*.pth
!backend/ml_models/efficientnet_b4_derma_v3_0.pth
backend/ml_models/*.pt
!backend/ml_models/yolov8n-seg.pt

