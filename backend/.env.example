# MongoDB Configuration
# Set to 'True' to enable MongoDB storage, 'False' to use local JSON file
USE_MONGODB=True

# Connection string (Required if USE_MONGODB=True)
# Example for local: mongodb://localhost:27017
# Example for Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017

# Database Name
MONGODB_DB_NAME=medai_dermatology
